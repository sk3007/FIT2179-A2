{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Growth of GDP vs. CO2 Emissions in Malaysia (1990-2024)"
  },
  "width": "container",
  "height": "container",
  "data": {
    "url": "data/co2-emissions-and-gdp.csv"
  },
  "transform": [
    {
      "fold": ["Increase in National GDP", "Increase in CO2 emissions"],
      "as": ["Growth Metric", "Percentage Increase"]
    }
  ],
  "layer": [
    {
      "mark": {"type": "line", "point": true, "interpolate": "monotone"},
      "encoding": {
        "x": {
          "field": "Year", 
          "type": "temporal", 
          "axis": {"labelAngle": -45}
        },
        "y": {
          "field": "Percentage Increase", 
          "type": "quantitative", 
          "title": "Percentage Increase (%)"
        },
        "color": {
          "field": "Growth Metric",
          "type": "nominal",
          "scale": {
            "domain": ["Increase in National GDP", "Increase in CO2 emissions"],
            "range": ["#2850bf", "#5c5955"] 
          },
          "legend": {"orient": "top-left", "title": "Growth Metrics"}
        },
        "tooltip": [
          {"field": "Year", "type": "temporal"},
          {"field": "Growth Metric", "type": "nominal"},
          {"field": "Percentage Increase", "type": "quantitative", "format": ".2f"}
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "Year": "1997-06-01",
            "Title": "2002:",
            "Annotation": [
              "GDP and emissions",
              "rise together, signalling",
              "that prosperity came with",
              "a climate cost."
            ],
            "yPosition": 300
          },
          {
            "Year": "2014-06-01",
            "Title": "2020:",
            "Annotation": [
              "GDP and emissions",
              "both dropped as COVID-19",
              "disrupted economic activity."
            ],
            "yPosition": 495
          },
          {
            "Year": "2019-01-01",
            "Title": "2023:",
            "Annotation": [
              "GDP continued rising,",
              "while emissions dropped,",
              "suggesting early decoupling",
              "from carbon-intensive",
              "growth as a result of",
              "COP28."
            ],
            "yPosition": 320
          }
        ]
      },
      "layer": [
        {
          "mark": {
            "type": "text",
            "align": "left",
            "baseline": "top",
            "color": "#374151",
            "fontWeight": "bold"
          },
          "encoding": {
            "x": {"field": "Year", "type": "temporal"},
            "y": {"field": "yPosition", "type": "quantitative"},
            "text": {"field": "Title"}
          }
        },
        {
          "mark": {
            "type": "text",
            "align": "left",
            "baseline": "top",
            "color": "#374151",
            "dy": 15 
          },
          "encoding": {
            "x": {"field": "Year", "type": "temporal"},
            "y": {"field": "yPosition", "type": "quantitative"},
            "text": {"field": "Annotation"}
          }
        }
      ]
    },
    {
      "data": {
        "values": [
          { "Year": "2002-01-01" },
          { "Year": "2020-01-01" },
          { "Year": "2023-01-01" }
        ]
      },
      "mark": {
        "type": "rule",
        "strokeDash": [4, 4],
        "color": "#9ca3af",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "temporal"
        }
      }
    }
  ]
}