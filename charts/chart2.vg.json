{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": "container",
  "title": {
    "text": "Tree Cover Loss in Malaysia",
    "subtitle": "Annual tree-cover loss as a percentage of state area, 2001-2021"
  },
  "projection": {
    "type": "mercator"
  },
  "params": [
    {
      "name": "SelectedYear",
      "value": 2001,
      "bind": {
        "input": "range",
        "min": 2001,
        "max": 2025,
        "step": 1,
        "name": "Select Year: "
      }
    }
  ],
  "layer": [
    {
      "data": {
        "url": "data/output (2).topojson",
        "format": {"type": "topojson", "feature": "mys_admin0"}
      },
      "mark": {"type": "geoshape", "fill": "#ddd", "stroke": "black", "strokeWidth": 1}
    },
    {
      "data": {
        "url": "data/tree_cover_loss_normalised.csv"
      },
      "transform": [
        {
          "filter": "datum.umd_tree_cover_loss__year == SelectedYear"
        },
        {
          "calculate": "datum.adm1 == 'Kuala Lumpur' ? 'W.P. Kuala Lumpur' : datum.adm1 == 'Labuan' ? 'W.P. Labuan' : datum.adm1 == 'Putrajaya' ? 'W.P. Putrajaya' : datum.adm1",
          "as": "adm1_matched"
        },
        {
          "lookup": "adm1_matched",
          "from": {
            "data": {
              "url": "data/output (2).topojson",
              "format": {
                "type": "topojson",
                "feature": "mys_admin1"
              }
            },
            "key": "properties.adm1_name"
          },
          "as": "geo"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#000000",
        "strokeWidth": 1
      },
      "encoding": {
        "shape": {
          "field": "geo",
          "type": "geojson"
        },
        "color": {
          "field": "tree_cover_loss_per_state_area",
          "type": "quantitative",
        "scale": {
            "type": "threshold",
            "domain": [0.1, 0.25, 0.5, 0.75, 1, 1.25, 1.5, 2, 3],
            "scheme": "yelloworangebrown"
          },
          "title": null,
          "legend": {
            "title": "Loss\n(% of state area)",
            "orient": "right",
            "direction": "vertical",            
            "gradientLength": 450,
            "gradientThickness": 14

          }
        },
        "tooltip": [
          {"field": "adm1", "type": "nominal", "title": "State"},
          {"field": "umd_tree_cover_loss__year", "type": "quantitative", "title": "Year"},
          {"field": "tree_cover_loss_per_state_area", "type": "quantitative", "title": "Loss (% of state area)", "format": ",.2f"}
        ]
      }
    },
    {
      "data": {
        "url": "data/output (2).topojson",
        "format": {"type": "topojson", "feature": "selection"}
      },
      "mark": {"type": "geoshape", "fill": "#e3e3e3", "stroke": "white", "strokeWidth":0.2}
    }
  ]
}