{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": "container",
  "title": {
    "text": "Tree Cover Loss in Malaysia"
  },
  "projection": {
    "type": "mercator"
  },
  "params": [
    {
      "name": "SelectedYear",
      "value": 2001,
      "bind": {
        "input": "range",
        "min": 2001,
        "max": 2021,
        "step": 1,
        "name": "Select Year: "
      }
    }
  ],
  "layer": [
    {
      "data": {
        "url": "data/output (2).topojson",
        "format": {"type": "topojson", "feature": "mys_admin0"}
      },
      "mark": {"type": "geoshape", "fill": "#ddd", "stroke": "black", "strokeWidth": 1}
    },
    {
      "data": {
        "url": "data/output (2).topojson",
        "format": {"type": "topojson", "feature": "mys_admin1"}
      },
      "mark": {"type": "geoshape", "fill": "#ffffff", "stroke": "black", "strokeWidth": 1}
    },
    {
      "data": {
        "url": "data/treecover_loss_by_region__ha.csv"
      },
      "transform": [
        {
          "filter": "datum.umd_tree_cover_loss__year == SelectedYear"
        },
        {
          "calculate": "datum.adm1 == 'Kuala Lumpur' ? 'W.P. Kuala Lumpur' : datum.adm1 == 'Labuan' ? 'W.P. Labuan' : datum.adm1 == 'Putrajaya' ? 'W.P. Putrajaya' : datum.adm1",
          "as": "adm1_matched"
        },
        {
          "lookup": "adm1_matched",
          "from": {
            "data": {
              "url": "data/output (2).topojson",
              "format": {
                "type": "topojson",
                "feature": "mys_admin1"
              }
            },
            "key": "properties.adm1_name"
          },
          "as": "geo"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#000000",
        "strokeWidth": 1
      },
      "encoding": {
        "shape": {
          "field": "geo",
          "type": "geojson"
        },
        "color": {
          "field": "umd_tree_cover_loss__ha",
          "type": "quantitative",
        "scale": {
            "type": "threshold",
            "domain": [1000, 5000, 10000, 20000, 30000, 50000, 100000, 200000],
            "scheme": "yelloworangebrown"
          },
          "title": "Loss (Hectares)"
        },
        "tooltip": [
          {"field": "adm1", "type": "nominal", "title": "State"},
          {"field": "umd_tree_cover_loss__year", "type": "quantitative", "title": "Year"},
          {"field": "umd_tree_cover_loss__ha", "type": "quantitative", "title": "Area Lost (ha)", "format": ",.2f"}
        ]
      }
    },
    {
      "data": {
        "url": "data/output (2).topojson",
        "format": {"type": "topojson", "feature": "selection"}
      },
      "mark": {"type": "geoshape", "fill": "#e3e3e3", "stroke": "white", "strokeWidth":0.2}
    }
  ]
}