{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": "container",
  "title": {
    "text": "Direct Economic Loss Attributed to Disasters in Malaysia"
  },
  "data": {
    "url": "data/direct-disaster-economic-loss.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "size": 20,
        "strokeWidth": 2,
        "color": "#c0392b"
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "axis": {
            "format": "d",
            "title": "Year"
          },
          "scale": {
            "zero": false,
            "domain": [2005, 2024]
          }
        },
        "y": {
          "field": "Direct economic loss attributed to disasters (current United States dollars)",
          "type": "quantitative",
          "title": "Economic Loss (USD)",
          "axis": {
            "format": "$,.0s"
          }
        },
        "tooltip": [
          {
            "field": "Year", 
            "type": "quantitative", 
            "title": "Year"
          },
          {
            "field": "Direct economic loss attributed to disasters (current United States dollars)", 
            "type": "quantitative", 
            "title": "Loss (USD)", 
            "format": "$,.0f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "regression": "Direct economic loss attributed to disasters (current United States dollars)",
          "on": "Year"
        }
      ],
      "mark": {
        "type": "line",
        "color": "#2980b9",
        "strokeDash": [5, 5],
        "strokeWidth": 2
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {
            "domain": [2005, 2024]
          }
        },
        "y": {
          "field": "Direct economic loss attributed to disasters (current United States dollars)",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "Direct economic loss attributed to disasters (current United States dollars)", 
            "type": "quantitative", 
            "title": "Trend Expected Loss", 
            "format": "$,.0f"
          }
        ]
      }
    },

    {
      "data": {
        "values": [
          {"Year": 2015, "Title": "2015", "text": ["Severe flooding in East Malaysia", "and Peninsular East Coast, affecting", "more than 500,000 people and", "causing significant economic losses."]}
        ]
      },
      "layer": [
        {
            "mark": {
                "type": "text",
                "align": "left",
                "baseline": "bottom",
                "dx": -150,
                "dy": -35,
                "fontWeight": "bold"
            },
            "encoding": {
                "x": {"field": "Year", "type": "quantitative", "scale": {"domain": [2005, 2024]}},
                "text": {"field": "Title", "type": "nominal"}
            }
        },

        {
            "mark": {
                "type": "text",
                "align": "left",
                "baseline": "bottom",
                "dx": -150,
                "dy": -20
            },
            "encoding": {
                "x": {"field": "Year", "type": "quantitative", "scale": {"domain": [2005, 2024]}},
                "text": {"field": "text", "type": "nominal"}
            }
        }
      ]
    },

    {
      "data": {
        "values": [
          {"Year": 2021, "Title": "2021", "text": ["Severe flooding in Klang Valley area", "caused by tropical depression.", "Widely noted as an extreme weather", "event linked to climate change."]}
        ]
      },
      "layer": [
        {
            "mark": {
                "type": "text",
                "align": "left",
                "baseline": "bottom",
                "dx": -230,
                "dy": -135,
                "fontWeight": "bold"
            },
            "encoding": {
                "x": {"field": "Year", "type": "quantitative", "scale": {"domain": [2005, 2024]}},
                "text": {"field": "Title", "type": "nominal"}
            }
        },

        {
            "mark": {
                "type": "text",
                "align": "left",
                "baseline": "bottom",
                "dx": -230,
                "dy": -120
            },
            "encoding": {
                "x": {"field": "Year", "type": "quantitative", "scale": {"domain": [2005, 2024]}},
                "text": {"field": "text", "type": "nominal"}
            }
        }
      ]
    }
  ]
}