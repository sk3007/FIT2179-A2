{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Bubble chart showing relationship between temperature, precipitation, and sea level change.",
  "width": "container",
  "height": "container",
  "title": {
    "text": "Temperature, Precipitation, and Sea Level Trends (1992-2024)",
    "subtitle": "Bubble Size = Annual Precipitation | Color = Sea Level Change"
  },
  "layer": [
        {
      "data": { "url": "data/viz2.csv" },
      "transform": [
        { "calculate": "parseFloat(datum.Date) + (1/12)", "as": "Date_end" }
      ],
      "mark": { "type": "rect", "opacity": 0.15, "clip": false },
      "encoding": {
        "x": { "field": "Date", "type": "quantitative", "title": "Year" },
        "x2": { "field": "Date_end" },
        "y": { "value": 0 },
        "y2": { "value": "height"},
        "color": {
          "field": "ONI Type",
          "type": "nominal",
          "scale": {
            "domain": ["El Niño", "ENSO Neutral", "La Niña"],
            "range": ["#e45756", "#cccccc", "#4f86f7"]
          },
          "legend": { "title": "ENSO Phase" }
        }
      }
    },
    {
        "data": {
            "url": "data/viz6.csv"
        },
        "mark": {
            "type": "circle",
            "opacity": 0.7,
            "stroke": "black",
            "strokeWidth": 0.5
        },
        "encoding": {
            "x": {
            "field": "Category",
            "type": "quantitative",
            "title": "Year",
            "axis": {
                "format": "d",
                "tickCount": 10
            },
            "scale": {
                "zero": false
            }
            },
            "y": {
            "field": "Average Mean Surface Air Temperature (°C)",
            "type": "quantitative",
            "title": "Mean Surface Temp (°C)",
            "scale": {
                "zero": false,
                "padding": 20
            }
            },
            "size": {
            "field": "Sea Level Change",
            "type": "quantitative",
            "title": "Sea Level Rise (mm)",
            "scale": {
                "type": "linear",
                "range": [20, 1000]
            }
            
            },
            "color": {
            "field": "Annual Precipitation",
            "type": "quantitative",
            "title": "Precipitation (mm)",
            "scale": {
                "zero": false,
                "scheme": "darkblue",
                "reverse": true
            }
            },
            "tooltip": [
            {
                "field": "Category",
                "type": "quantitative",
                "title": "Year"
            },
            {
                "field": "Average Mean Surface Air Temperature (°C)",
                "type": "quantitative",
                "title": "Temperature (°C)"
            },
            {
                "field": "Annual Precipitation",
                "type": "quantitative",
                "title": "Precipitation (mm)"
            },
            {
                "field": "Sea Level Change",
                "type": "quantitative",
                "title": "Sea Level Change (mm)",
                "format": ".2f"
            }
            ]
        }
    }
  ],
  "config": {
        "axis": {
        "grid": true,
        "gridOpacity": 0.4
        }
    }
}