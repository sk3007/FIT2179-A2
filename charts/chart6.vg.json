{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Warming stripes chart showing mean surface air temperature from 1950 to 2024.",
  "title": {
    "text": "Average Mean Surface Air Temperature (1950-2024)",
    "subtitle": "Strip chart showing the warming trend over time",
    "anchor": "start",
    "fontSize": 16
  },
  "width": 800,
  "height": 200,
  "data": {
    "url": "data/viz6.csv"
  },
  "mark": {
    "type": "rect",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "Category",
      "type": "ordinal",
      "title": "Year",
      "axis": {
        "values": ["1950", "1960", "1970", "1980", "1990", "2000", "2010", "2020"],
        "labelAngle": -45
      }
    },
    "color": {
      "field": "Average Mean Surface Air Temperature (°C)",
      "type": "quantitative",
      "title": "Temp (°C)",
      "scale": {
        "scheme": "redblue",
        "reverse": true,
        "domainMid": 25.3
      },
      "legend": {
        "orient": "right",
        "title": "Temperature (°C)"
      }
    },
    "tooltip": [
      {"field": "Category", "type": "ordinal", "title": "Year"},
      {
        "field": "Average Mean Surface Air Temperature (°C)",
        "type": "quantitative",
        "title": "Mean Temp",
        "format": ".2f"
      }
    ]
  },
  "config": {
    "view": {"stroke": null},
    "axis": {"domain": false, "ticks": false, "labelPadding": 10}
  }
}